{
  "version": 2,
  "name": "energylens-ai",
  "buildCommand": null,
  "outputDirectory": "static",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
